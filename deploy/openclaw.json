{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "plugins": {
    "entries": {
      "openai": {
        "enabled": true
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/data/workspace",
      "userTimezone": "America/Chicago",
      "model": {
        "primary": "openai/gpt-5.4",
        "fallbacks": ["openai/gpt-5.4-mini"]
      },
      "thinkingDefault": "low",
      "skills": ["taskflow", "summarize", "weather", "healthcheck"],
      "heartbeat": {
        "every": "1h",
        "target": "telegram",
        "lightContext": true,
        "activeHours": {
          "start": "07:00",
          "end": "20:00",
          "timezone": "America/Chicago"
        }
      }
    }
  },
  "tools": {
    "profile": "coding",
    "allow": ["gateway"]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "streaming": {
        "mode": "partial"
      },
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  }
}
