{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "plugins": {
    "entries": {
      "google-gemini": {
        "enabled": true
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/data/workspace",
      "userTimezone": "America/Chicago",
      "model": {
        "primary": "google-gemini/gemini-2.5-pro",
        "fallbacks": ["google-gemini/gemini-2.5-flash"]
      },
      "thinkingDefault": "low",
      "skills": ["taskflow", "summarize", "weather", "healthcheck", "composio"],
      "heartbeat": {
        "every": "1h",
        "target": "slack",
        "lightContext": true,
        "activeHours": {
          "start": "07:00",
          "end": "20:00",
          "timezone": "America/Chicago"
        }
      }
    }
  },
  "mcp": {
    "servers": {
      "composio": {
        "url": "https://connect.composio.dev/mcp",
        "transport": "streamable-http",
        "headers": {
          "x-consumer-api-key": "${COMPOSIO_API_KEY}"
        }
      }
    }
  },
  "tools": {
    "profile": "coding"
  },
  "channels": {
    "slack": {
      "enabled": true,
      "dmPolicy": "pairing",
      "streaming": {
        "mode": "partial"
      }
    }
  }
}
